# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Anthropic (brief analysis)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-api-key

# -----------------------------------------------------------------------------
# AIDEN Gateway (billing + tokens)
# Gateway owns Stripe webhooks, checkout, and token balances.
# -----------------------------------------------------------------------------
GATEWAY_URL=https://www.aiden.services
AIDEN_SERVICE_KEY=your-aiden-service-key

# -----------------------------------------------------------------------------
# AIDEN API (required by server env validation; used by /api/analyze-brief, health)
# Defaults to Railway production if AIDEN_API_URL is unset.
# -----------------------------------------------------------------------------
AIDEN_API_KEY=
AIDEN_API_URL=

# -----------------------------------------------------------------------------
# AIDEN Brain (optional; demo / brain routes — override default Railway base URL)
# -----------------------------------------------------------------------------
AIDEN_BRAIN_API_URL=
AIDEN_BRAIN_API_KEY=

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
FROM_EMAIL=Brief Sharpener <hello@aiden.services>

# -----------------------------------------------------------------------------
# Sentry (optional — error monitoring; leave empty to disable client/server reporting)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# App URLs & analytics (optional)
# NEXT_PUBLIC_URL — canonical site URL for redirects, sitemap, metadata
# NEXT_PUBLIC_GA_MEASUREMENT_ID — Google Analytics 4 (G-xxxxxxxx); omit to disable
# -----------------------------------------------------------------------------
NEXT_PUBLIC_URL=https://yourdomain.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# -----------------------------------------------------------------------------
# Budget caps (USD) — protects against free-tier abuse
# -----------------------------------------------------------------------------
DAILY_BUDGET_USD=20
MONTHLY_BUDGET_USD=300
DAILY_FREE_BUDGET_USD=10
ADMIN_API_SECRET=your-admin-secret-for-cost-dashboard
